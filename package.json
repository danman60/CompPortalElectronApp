{
  "name": "compsync-media",
  "version": "2.6.0",
  "description": "CompSync Media — OBS recording control, audio splitting, photo import, and upload for dance competitions",
  "author": "CompSync <danieljohnabrahamson@gmail.com>",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:wpd-helper": "dotnet publish tools/wpd-helper/wpd-helper.csproj -c Release -r win-x64 --self-contained false -p:PublishSingleFile=true -o tools/wpd-helper/bin",
    "build:wpd-helper:self-contained": "dotnet publish tools/wpd-helper/wpd-helper.csproj -c Release -r win-x64 --self-contained true -p:PublishSingleFile=true -o tools/wpd-helper/bin",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "predist": "bash scripts/fetch-ffmpeg-win.sh && npm run build:wpd-helper",
    "dist": "electron-vite build && electron-builder --win --dir",
    "predist:installer": "bash scripts/fetch-ffmpeg-win.sh && npm run build:wpd-helper",
    "dist:installer": "electron-vite build && electron-builder --win"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@img/sharp-win32-x64": "^0.33.5",
    "chokidar": "^4.0.3",
    "electron-log": "^5.1.1",
    "electron-store": "^6.0.1",
    "electron-window-state": "^5.0.3",
    "exifreader": "^4.23.0",
    "express": "^4.21.0",
    "ffmpeg-static": "^5.2.0",
    "obs-websocket-js": "^5.0.6",
    "papaparse": "^5.4.1",
    "sharp": "^0.33.5",
    "ws": "^8.19.0",
    "xlsx": "^0.18.5",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1004.0",
    "@playwright/test": "^1.58.2",
    "@types/express": "^4.17.21",
    "@types/papaparse": "^5.3.14",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.3"
  },
  "build": {
    "appId": "net.compsync.media",
    "productName": "CompSync Media",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "!node_modules/ffmpeg-static/**/*"
    ],
    "asarUnpack": [
      "node_modules/sharp/**/*",
      "node_modules/@img/**/*",
      "node_modules/@huggingface/transformers/**/*",
      "node_modules/onnxruntime-node/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/ffmpeg/ffmpeg.exe",
        "to": "ffmpeg.exe"
      },
      {
        "from": "tools/wpd-helper/bin/wpd-helper.exe",
        "to": "wpd-helper.exe"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "dir"
      ],
      "icon": "resources/icon.ico",
      "signAndEditExecutable": false
    },
    "electronLanguages": [
      "en-US"
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico"
    }
  }
}
